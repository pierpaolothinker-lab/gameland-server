{
    "compilerOptions":  {
                            "module":  "NodeNext",
                            "moduleResolution":  "NodeNext",
                            "baseUrl":  "src",
                            "outDir":  "dis",
                            "sourceMap":  true,
                            "noImplicitAny":  true,
                            "esModuleInterop":  true,
                            "allowSyntheticDefaultImports":  true
                        },
    "include":  [
                    "src/**/*",
                    "tests/**/*"
                ]
}

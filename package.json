                            "@types/cors":  "^2.8.17",
                            "@types/express":  "^4.17.21",
                            "@types/jest":  "^29.5.12",
                            "@types/mongoose":  "^5.11.97",
                            "@types/socket.io":  "^3.0.2",
                            "jest":  "^29.7.0",
                            "nodemon":  "^3.1.4",
                            "ts-jest":  "^29.2.0",
                            "ts-node":  "^10.9.2",
                            "typescript":  "^5.5.3"
                        },
    "dependencies":  {
                         "body-parser":  "^1.20.2",
